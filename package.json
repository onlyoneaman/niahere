{
  "name": "niahere",
  "version": "0.1.1",
  "description": "A personal AI assistant daemon — scheduled jobs, terminal chat, and Telegram, powered by Claude.",
  "type": "module",
  "scripts": {
    "start": "bun run src/cli/index.ts start",
    "stop": "bun run src/cli/index.ts stop",
    "status": "bun run src/cli/index.ts status",
    "dev": "bun run src/cli/index.ts run",
    "test": "bun test",
    "seed": "bun run src/db/seed.ts"
  },
  "keywords": [
    "ai",
    "assistant",
    "sidekick",
    "agent",
    "cron"
  ],
  "bin": {
    "nia": "src/cli/index.ts"
  },
  "author": "Aman",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.9.3"
  }
}
