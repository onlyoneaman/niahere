{
  "name": "niahere",
  "version": "0.2.9",
  "description": "A personal AI assistant daemon — scheduled jobs, chat across Telegram and Slack, persona system, and visual identity.",
  "type": "module",
  "scripts": {
    "start": "bun run src/cli/index.ts start",
    "stop": "bun run src/cli/index.ts stop",
    "status": "bun run src/cli/index.ts status",
    "dev": "bun run src/cli/index.ts run",
    "test": "tsc --noEmit && LOG_LEVEL=silent bun test --reporter=dots",
    "test:bun": "bun test",
    "typecheck": "tsc --noEmit",
    "seed": "bun run src/db/seed.ts",
    "release": "npm version patch && npm publish && git push"
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "daemon",
    "telegram",
    "slack",
    "cron",
    "claude"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "nia": "bin/nia"
  },
  "files": [
    "bin/",
    "src/",
    "defaults/",
    "skills/",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "author": "Aman (https://amankumar.ai)",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "cron-parser": "^5.5.0",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.9.3"
  }
}
