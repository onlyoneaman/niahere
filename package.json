{
  "name": "niahere",
  "version": "0.2.0",
  "description": "A personal AI assistant daemon — scheduled jobs, terminal chat, and Telegram.",
  "type": "module",
  "scripts": {
    "start": "bun run src/cli/index.ts start",
    "stop": "bun run src/cli/index.ts stop",
    "status": "bun run src/cli/index.ts status",
    "dev": "bun run src/cli/index.ts run",
    "test": "tsc --noEmit && LOG_LEVEL=silent bun test --reporter=dots",
    "test:bun": "bun test",
    "typecheck": "tsc --noEmit",
    "seed": "bun run src/db/seed.ts"
  },
  "keywords": [
    "ai",
    "assistant",
    "sidekick",
    "agent",
    "cron"
  ],
  "bin": {
    "nia": "src/cli/index.ts"
  },
  "author": "Aman",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "cron-parser": "^5.5.0",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.9.3"
  }
}
